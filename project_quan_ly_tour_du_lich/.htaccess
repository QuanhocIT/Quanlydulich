Options -Indexes

# ── Force HTTPS (skip on localhost / 127.0.0.1) ────────────────────────────
RewriteEngine On
# HTTPS redirect handled in index.php for APP_ENV=production
# (disabled here to support ngrok tunneling in development)

# ── Block direct access to sensitive file types ─────────────────────────────
<FilesMatch "\.(env|log|json|sql|md|sh|bak|ini|gitignore|gitkeep|lock|pem|key|crt)$">
    Require all denied
</FilesMatch>

# ── Block access to hidden dot-files ────────────────────────────────────────
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
