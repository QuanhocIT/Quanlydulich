# Base URL
BASE_URL=http://localhost/du_an_1-main/project_quan_ly_tour_du_lich/

# Runtime environment: local | production
APP_ENV=local
# Static asset version for CSS/JS cache busting
ASSET_VERSION=1

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=quan_ly_tour_du_lich

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/du_an_1-main/project_quan_ly_tour_du_lich/google_callback.php

# Mail delivery
MAIL_ENABLED=1
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=AVENTURA
MAIL_REPLY_TO=support@example.com
MAIL_REPLY_TO_NAME=AVENTURA Support
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_AUTH=1
SMTP_TIMEOUT=20

# Payment mode: mock | vnpay | manual_qr
PAYMENT_MODE=vnpay

# VNPay config
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost/du_an_1-main/project_quan_ly_tour_du_lich/index.php?act=payment/callback

# QR manual transfer config (used when PAYMENT_MODE=manual_qr)
QR_PAYMENT_IMAGE_URL=/public/uploads/qr/image.png
QR_PAYMENT_ACCOUNT_NAME=
QR_PAYMENT_ACCOUNT_NUMBER=
QR_PAYMENT_BANK_NAME=MB Bank
QR_PAYMENT_TRANSFER_NOTE_HINT=TEN + SDT + BOOKING_ID

# Bank webhook auto-confirm (for Casso/SePay)
BANK_WEBHOOK_ENABLED=0
BANK_WEBHOOK_PROVIDER=custom
BANK_WEBHOOK_SECRET=
BANK_WEBHOOK_ALLOW_OVERPAY=1

# Performance diagnostics (optional; use only when investigating slowness)
# Adds X-Perf-* headers to responses
PERF_HEADER_ENABLED=0
# Logs slow requests as JSON lines to storage/perf.log
PERF_LOG_ENABLED=0
# Threshold to log a request (ms)
PERF_SLOW_MS=800
# Enable PDO statement profiling (adds small overhead)
PERF_DB_PROFILE=0
# Mark a SQL statement as "slow" (ms) and include in perf.log (max PERF_DB_SLOW_MAX statements)
PERF_DB_SLOW_MS=120
PERF_DB_SLOW_MAX=5
